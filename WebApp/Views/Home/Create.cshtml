@model Proyector
@{
    ViewData["Title"] = "Nuevo proyector";
}

<div class="container">
    <h1 class="display-5 mb-3">Nuevo proyector</h1>
    <div class="row">
        <form asp-controller="Home" asp-action="Create">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group mb-3">
                <label class="form-label" asp-for="id">Número de proyector:</label>
                <input type="number" class="form-control" asp-for="id" id="id"/>
                <span asp-validation-for="id" class="text-bg-danger"></span>
            </div>

            <div class="form-group mb-3">                
                <label class="form-label" asp-for="Marca">Marca del proyector:</label>
                <input type="text" class="form-control" asp-for="Marca" id="Marca" />
                <span asp-validation-for="Marca" class="text-bg-danger"></span>
            </div>

            <div class="form-group mb-3">            
                <label class="form-label" asp-for="Modelo">Modelo del proyector:</label>
                <input type="text" class="form-control" asp-for="Modelo" id="Modelo"/>
                <span asp-validation-for="Modelo" class="text-bg-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="NumeroDeSerie">Numero de serie:</label>
                <input type="text" class="form-control" asp-for="NumeroDeSerie" id="NumeroDeSerie" />
                <span asp-validation-for="NumeroDeSerie" class="text-bg-danger"></span>
            </div>

            <div class="form-group mb-3">
                <label class="form-label" asp-for="FechDeAlta">Fecha de alta: </label>
                <input type="date" class="form-control" asp-for="FechDeAlta" id="FechaDeAlta" />
            </div>

            <div class="form-grup mb-3">
                <label class="form-label" asp-for="Situacion"> Situacion del proyector:</label>
            <select class="form-select" asp-for="Situacion" id="Situacion">
                <option value="1">Bueno</option>
                <option value="2">Regular</option>
                <option value="3">Malo</option>
            </select>
            </div>

            <div class="form-group mb-3">
                <button type="submit" class="btn btn-primary ">Guardar</button>
                <a class="btn btn-secondary " asp-controller="Home" asp-action="Index">Cancelar</a>
            </div>
        </form>
    </div>
</div>

